{
  "name": "codeharness",
  "version": "1.0.0",
  "description": "AI Coding Agent Harness - A governance framework for AI coding agents",
  "main": "dist/src/index.js",
  "bin": {
    "codeharness": "./dist/src/index.js"
  },
  "scripts": {
    "test": "jest --passWithNoTests",
    "test:coverage": "jest --coverage",
    "build": "tsc",
    "lint": "eslint src/ tests/",
    "format": "prettier --write .",
    "prepare": "husky",
    "prepublishOnly": "npm run build && npm test"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "keywords": [
    "ai",
    "coding-agent",
    "cli",
    "llm",
    "governance",
    "guardrails"
  ],
  "author": "CodeHarness",
  "license": "ISC",
  "type": "module",
  "files": [
    "dist/src/",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@swc/core": "^1.15.43",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^29.5.14",
    "@types/node": "^26.1.0",
    "@types/semver": "^7.7.1",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "c8": "^11.0.0",
    "eslint": "^8.57.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "ts-jest": "^29.4.11",
    "typescript": "^5.5.2"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^12.0.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "semver": "^7.8.5",
    "zod": "^4.4.3"
  }
}